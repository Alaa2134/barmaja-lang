{
  "name": "barmaja-language",
  "displayName": "لغة بَرمَجة - Barmaja Language",
  "description": "لغة برمجة عربية بديلة لـ JavaScript - Arabic Programming Language",
  "version": "1.0.0",
  "publisher": "alaa-saber",
  "author": {
    "name": "علاء صابر",
    "email": "alaa@example.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Alaa2134/barmaja-lang"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Themes"
  ],
  "keywords": [
    "arabic",
    "programming",
    "language",
    "javascript",
    "عربي",
    "برمجة"
  ],
  "activationEvents": [
    "onLanguage:barmaja"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "barmaja",
        "aliases": [
          "بَرمَجة",
          "Barmaja"
        ],
        "extensions": [
          ".brm",
          ".برم"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "barmaja",
        "scopeName": "source.barmaja",
        "path": "./syntaxes/barmaja.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "barmaja.transpile",
        "title": "Barmaja: Transpile to JavaScript"
      },
      {
        "command": "barmaja.run",
        "title": "Barmaja: Run Code"
      }
    ],
    "keybindings": [
      {
        "command": "barmaja.transpile",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "editorLangId == barmaja"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/glob": "^7.1.3",
    "@types/node": "^12.11.7",
    "eslint": "^7.19.0",
    "@typescript-eslint/eslint-plugin": "^4.14.1",
    "@typescript-eslint/parser": "^4.14.1",
    "glob": "^7.1.6",
    "mocha": "^8.2.1",
    "@types/mocha": "^8.2.0",
    "typescript": "^4.1.3",
    "vscode-test": "^1.5.0"
  },
  "dependencies": {
    "vscode-languageclient": "^7.0.0"
  }
}
